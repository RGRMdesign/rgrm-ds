{
  "name": "rgrm-ds",
  "version": "0.0.0",
  "private": true,
  "description": "RGRM design system monorepo (CSS-only components built on @rgrmdesign/rgrm-ds-tokens).",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean": "turbo run clean && rimraf node_modules/.cache .turbo",
    "format": "prettier --write \"**/*.{css,js,ts,json,md,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{css,js,ts,json,md,html,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.9.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lightningcss-cli"
    ]
  }
}
