    "@storybook/react-vite": "^10.4.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "chromatic": "^17.4.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.0.1",
