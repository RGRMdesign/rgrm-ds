{
  "name": "@rgrmdesign/rgrm-ds-elements",
  "version": "0.7.1",
  "description": "Web Components for the RGRM design system. Styles come from @rgrmdesign/rgrm-ds-css.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RGRMdesign/rgrm-ds.git",
    "directory": "packages/elements"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./badge": {
      "types": "./dist/badge/index.d.ts",
      "import": "./dist/badge/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./heading": {
      "types": "./dist/heading/index.d.ts",
      "import": "./dist/heading/index.js"
    },
    "./inline": {
      "types": "./dist/inline/index.d.ts",
      "import": "./dist/inline/index.js"
    },
    "./link": {
      "types": "./dist/link/index.d.ts",
      "import": "./dist/link/index.js"
    },
    "./paragraph": {
      "types": "./dist/paragraph/index.d.ts",
      "import": "./dist/paragraph/index.js"
    },
    "./root": {
      "types": "./dist/root/index.d.ts",
      "import": "./dist/root/index.js"
    },
    "./section": {
      "types": "./dist/section/index.d.ts",
      "import": "./dist/section/index.js"
    },
    "./stack": {
      "types": "./dist/stack/index.d.ts",
      "import": "./dist/stack/index.js"
    },
    "./fonts": {
      "import": "./dist/fonts.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "@rgrmdesign/rgrm-ds-css",
    "./dist/fonts.js",
    "./dist/index.js",
    "./dist/badge/index.js",
    "./dist/button/index.js",
    "./dist/heading/index.js",
    "./dist/paragraph/index.js",
    "./dist/root/index.js",
    "./dist/section/index.js",
    "./dist/inline/index.js",
    "./dist/link/index.js",
    "./dist/stack/index.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@rgrmdesign/rgrm-ds-core": "workspace:*",
    "@rgrmdesign/rgrm-ds-css": "workspace:*"
  },
  "peerDependencies": {
    "@rgrmdesign/rgrm-ds-tokens": ">=0.13.1"
  },
  "devDependencies": {
    "@rgrmdesign/rgrm-ds-tokens": "^0.13.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "custom-elements",
    "design-system",
    "typography",
    "web-components"
  ],
  "publishConfig": {
    "access": "public"
  }
}
