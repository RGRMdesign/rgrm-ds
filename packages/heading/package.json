{
  "name": "@rgrmdesign/heading",
  "version": "0.0.0",
  "description": "Heading styles for the RGRM design system, built on @rgrmdesign/rgrm-ds-tokens.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.css",
  "style": "dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./index.css": "./dist/index.css",
    "./source": "./src/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && lightningcss --minify --bundle --targets \">= 0.25%\" src/index.css -o dist/index.css",
    "dev": "chokidar \"src/**/*.css\" -c \"pnpm run build\" --initial",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@rgrmdesign/rgrm-ds-tokens": ">=0.1.1"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "lightningcss-cli": "^1.32.0",
    "rimraf": "^6.0.1"
  },
  "keywords": [
    "design-system",
    "css",
    "heading",
    "typography"
  ],
  "publishConfig": {
    "access": "public"
  }
}
