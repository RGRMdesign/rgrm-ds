{
  "name": "@rgrmdesign/rgrm-ds-core",
  "version": "0.4.2",
  "description": "Framework-agnostic logic (class name builders, shared types) for the RGRM design system.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RGRMdesign/rgrm-ds.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./heading": {
      "types": "./dist/heading/index.d.ts",
      "import": "./dist/heading/index.js"
    },
    "./inline": {
      "types": "./dist/inline/index.d.ts",
      "import": "./dist/inline/index.js"
    },
    "./paragraph": {
      "types": "./dist/paragraph/index.d.ts",
      "import": "./dist/paragraph/index.js"
    },
    "./root": {
      "types": "./dist/root/index.d.ts",
      "import": "./dist/root/index.js"
    },
    "./section": {
      "types": "./dist/section/index.d.ts",
      "import": "./dist/section/index.js"
    },
    "./stack": {
      "types": "./dist/stack/index.d.ts",
      "import": "./dist/stack/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "design-system",
    "core",
    "typography"
  ],
  "publishConfig": {
    "access": "public"
  }
}
